---
// \source\html\components\tooltip.astro
const { TITLE, ALT_TITLE, DESCRIPTION, NOTES, TAGS, TYPE, STUDIO, ICON_YEAR, RATING, STREAMS, ANILIST_ID, CRUNCHYROLL_ID, HIDIVE_ID } = Astro.props;

/// populate variables for use in template
// if props are null/undefined, set to error message, allow empty strings/arrays
const title = TITLE ?? "[ASTRO COMPONENT TOOLTIP ERROR :: TITLE MISSING]";
const alt_title = ALT_TITLE ?? "[ASTRO COMPONENT TOOLTIP ERROR :: ALT_TITLE MISSING]";
const type = TYPE ?? "[ASTRO COMPONENT TOOLTIP ERROR :: TYPE MISSING]";
const studio = STUDIO ?? "[ASTRO COMPONENT TOOLTIP ERROR :: STUDIO MISSING]";
const iconYear = ICON_YEAR ?? "[ASTRO COMPONENT TOOLTIP ERROR :: ICON_YEAR MISSING]";
const rating = RATING ?? "[ASTRO COMPONENT TOOLTIP ERROR :: RATING MISSING]";
const description = DESCRIPTION ?? "[ASTRO COMPONENT TOOLTIP ERROR :: DESCRIPTION MISSING]";
const notes = NOTES ?? ["[ASTRO COMPONENT TOOLTIP ERROR :: NOTES MISSING]"];
const Tags = TAGS ?? ["[ASTRO COMPONENT TOOLTIP ERROR :: TAGS MISSING]"];
const streams = STREAMS ?? [];

///
// this is the template for generating tooltips for anime cards
///
---
<div>
    { (ANILIST_ID || CRUNCHYROLL_ID || HIDIVE_ID) && (
        <div class="debug-ids" style="font-family: monospace; font-size: 0.75rem; color: #ffc107; margin-bottom: 0.25rem;">
            [DEBUG] AL: {ANILIST_ID || 'N/A'} | CR: {CRUNCHYROLL_ID || 'N/A'} | HD: {HIDIVE_ID || 'N/A'}
        </div>
    )}
    <h5 class="theme-font">{title}</h5>
    { alt_title && (<h6 class="theme-font tooltip-alt">Alt title: {alt_title}</h6>) }
    { (type && studio && iconYear && rating) &&
        (<ul class="entryBar">
            { type && <li class="type">{type}</li> }
            { studio && <li>{studio}</li> }
            { iconYear && <li class="iconYear">{iconYear}</li> }

            { rating && (
                <li>
                    <div class="ttRating">{rating}</div>
                </li>
            ) }
        </ul>)
    }
    { description && (<p>{description}</p>) }

    { streams && streams.length > 0 && (
        <div class="streams mb-2">
            <h4>Available On</h4>
            <ul style="list-style: none; padding: 0; display: flex; gap: 0.5rem; margin-bottom: 0;">
                {streams.map((s: any) => (
                    <li>
                        <a href={s.url || s.u} target="_blank" rel="noopener noreferrer" class="badge text-bg-warning text-dark text-decoration-none">
                            {s.platform || s.p}
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    )}

    { notes.length > 0 && (
        <div class="tooltip notes">
            { notes && (
                notes.map((note: string) => (
                    <p>{note}</p>
                ))
            )}
        </div>
    )}
    { Tags.length > 0 && (
        <div class="tags">
            <h4>Tags</h4>
            <ul>
                {Tags.map((tag: string) => (
                    <li>{tag}</li>
                ))}
            </ul>
        </div>
    )}
</div>