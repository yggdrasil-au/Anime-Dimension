{
	auto_https off
}

:{$PORT}
root * {$DOCUMENT_ROOT}

encode zstd gzip

@deny_sensitive path_regexp deny_sensitive (^|/)\.ht(access|passwd)$
respond @deny_sensitive 403

@allowed_origin expression `{http.request.header.Origin}.matches("^https://([a-zA-Z0-9-]+\\.)*anime-dimension\\.com$") || {http.request.header.Origin} == "https://api.anime-dimension.com"`
header @allowed_origin Access-Control-Allow-Origin {http.request.header.Origin}
header @allowed_origin Vary Origin

@asset path /dist/* /data/* /manifest/* /site.webmanifest /favicon* /robots.txt
header @asset Cache-Control "public, max-age=31536000, immutable"

@non_asset not path /dist/* /data/* /manifest/* /site.webmanifest /favicon* /robots.txt
header @non_asset Cache-Control "max-age=604800, public"

@spa {
	not file
}
rewrite @spa /index.html

file_server
